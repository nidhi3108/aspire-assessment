    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
